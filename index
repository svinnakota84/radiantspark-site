<script>
/* ── Page navigation ── */
function updatePage() {
  const hash = window.location.hash || '#it';
  document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('nav a').forEach(a => a.classList.remove('active-nav'));

  if (hash === '#india') {
    document.getElementById('india-page').classList.add('active');
    document.getElementById('nav-india').classList.add('active-nav');
  } else if (hash === '#about') {
    document.getElementById('about-page').classList.add('active');
    document.getElementById('nav-about').classList.add('active-nav');
  } else {
    document.getElementById('it-page').classList.add('active');
    document.getElementById('nav-it').classList.add('active-nav');
  }
}
window.addEventListener('hashchange', updatePage);
window.addEventListener('load', updatePage);

/* ── Chatbot toggle ── */
const toggle  = document.getElementById('chat-toggle');
const chatbox = document.getElementById('chatbox');
toggle.addEventListener('click', () => {
  chatbox.classList.toggle('open');
  toggle.textContent = chatbox.classList.contains('open') ? '✕' : '💬';
});

/* ── AI Chat ── */
const SYSTEM_PROMPT = `You are Radiant Intelligence, the official AI assistant for Radiant Spark Global — a multi-sector enterprise headquartered in Guntur and Amaravati, Andhra Pradesh, India, with US IT operations under Radiant Spark LLC (radiantsparkllc.com).

INDIA DIVISIONS:
1. Solar & EV Charging – Solar power solutions and EV charging station networks across Andhra Pradesh.
2. Sparkle Beverages – Premium drink manufacturing and wholesale distribution. FSSAI licensed, GST compliant.
3. Sparkle Distribution Network – In-house last-mile delivery fleet serving Sparkle Beverages and cargo, powered by solar energy.

USA DIVISIONS — Radiant Spark LLC:
4. Business Transformation – End-to-end enterprise re-engineering and process optimisation.
5. Digital Transformation – Cloud-first modernisation, automation and digital strategy.
6. Artificial Intelligence – AI strategy, model deployment and AI server infrastructure.
7. Technology – Cloud infrastructure, system integration and enterprise tech.
8. Solutions – Custom software development and platform solutions.
9. IT Consulting – Oracle Fusion HCM, SQL troubleshooting, systems advisory.
10. IT Staffing – Technology talent placement and workforce solutions across the USA.

USEFUL LINKS: Apply For Job, Join Our Talent Group, Contact.
Tagline: "Powering Guntur's Growth, One Seamless Delivery at a Time."
Website: radiantsparkllc.com

Be friendly, concise and professional. Keep replies under 3 sentences unless detail is needed. Help customers with services, careers, EV, beverages, distribution, and IT consulting questions.`;

let chatHistory = [];
const msgsEl = document.getElementById('chat-messages');

function addMsg(text, type) {
  const div = document.createElement('div');
  div.className = 'msg ' + type;
  div.textContent = text;
  msgsEl.appendChild(div);
  msgsEl.scrollTop = msgsEl.scrollHeight;
  return div;
}

function addTyping() {
  const div = document.createElement('div');
  div.className = 'msg ai';
  div.id = 'typing-ind';
  div.innerHTML = '<span class="typing-dots"><span>●</span><span>●</span><span>●</span></span>';
  msgsEl.appendChild(div);
  msgsEl.scrollTop = msgsEl.scrollHeight;
}
function removeTyping() {
  const el = document.getElementById('typing-ind');
  if (el) el.remove();
}

function sendQuick(text) {
  document.getElementById('quickReplies').style.display = 'none';
  go(text);
}

function go(text) {
  addMsg(text, 'user');
  chatHistory.push({ role: 'user', content: text });
  addTyping();
  callAPI();
}

document.getElementById('chat-form').addEventListener('submit', e => {
  e.preventDefault();
  const inp = document.getElementById('chat-input');
  const val = inp.value.trim();
  if (!val) return;
  inp.value = '';
  document.getElementById('quickReplies').style.display = 'none';
  go(val);
});

async function callAPI() {
  try {
    const res = await fetch('[https://api.anthropic.com/v1/messages](https://api.anthropic.com/v1/messages)', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        model: 'claude-sonnet-4-20250514',
        max_tokens: 1000,
        system: SYSTEM_PROMPT,
        messages: chatHistory
      })
    });
    const data = await res.json();
    removeTyping();
    const reply = data?.content?.[0]?.text || "I'm having trouble connecting. Please try again shortly.";
    chatHistory.push({ role: 'assistant', content: reply });
    addMsg(reply, 'ai');
  } catch (err) {
    removeTyping();
    const e = addMsg('Connection error — please try again.', 'ai');
    e.style.color = '#f87171';
  }
}
</script>
