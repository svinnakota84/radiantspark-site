<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Radiant Spark Global | US & India</title>
<style>
  :root {
    --primary: #2563eb;   /* Deep Blue */
    --accent: #059669;    /* Emerald Green */
    --solar: #d97706;     /* Golden / Solar Orange */
    --dark-bg: #030712;
    --card-bg: rgba(17, 24, 39, 0.95);
  }

  body { 
    margin: 0; font-family: 'Inter', sans-serif; 
    background: var(--dark-bg); color: #e5e7eb; 
    line-height: 1.6; overflow-x: hidden;
  }

  /* Vibrant Header */
  header { 
    background: rgba(3, 7, 18, 0.95);
    backdrop-filter: blur(15px);
    border-bottom: 2px solid var(--primary);
    padding: 25px; text-align: center; 
    position: sticky; top: 0; z-index: 1000;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 15px;
  }

  .logo-container {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .site-logo {
    height: 60px;
    width: auto;
    object-fit: contain;
  }

  header h1 { 
    margin: 0; font-size: 2.4rem; font-weight: 800;
    background: linear-gradient(90deg, #2563eb, #d97706, #059669);
    -webkit-background-clip: text; -webkit-text-fill-color: transparent;
  }
  
  nav { margin-top: 5px; }
  nav a { 
    margin: 0 16px; color: #9ca3af; text-decoration: none;
    font-size: 0.85rem; font-weight: 600; letter-spacing: 1.2px;
    transition: 0.3s; text-transform: uppercase;
  }
  nav a:hover { color: var(--solar); }

  main { max-width: 1200px; margin: 40px auto; padding: 0 20px; }

  /* Hero Sections */
  .hero { 
    height: 400px; display: flex; align-items: center; justify-content: center; 
    text-align: center; border-radius: 32px; background-size: cover; 
    background-position: center; position: relative; overflow: hidden;
    margin-bottom: 50px; border: 1px solid rgba(255,255,255,0.08);
  }

  .hero::before { 
    content: ''; position: absolute; inset: 0; 
    background: linear-gradient(to bottom, rgba(0,0,0,0.4), rgba(0,0,0,0.85)); 
  }

  .hero h2 { position: relative; z-index: 1; font-size: 3.5rem; color: #ffffff; text-shadow: 0 4px 20px rgba(0,0,0,0.9); }

  /* Content Styling */
  .about-content {
    background: var(--card-bg);
    padding: 45px;
    border-radius: 32px;
    border: 1px solid rgba(255,255,255,0.08);
    margin-bottom: 40px;
    box-shadow: 0 20px 40px rgba(0,0,0,0.4);
  }
  .about-content h2 { color: var(--solar); font-size: 2.4rem; margin-top: 0; }
  .about-content h3 { color: var(--primary); margin-top: 35px; border-left: 5px solid var(--accent); padding-left: 18px; }
  .about-content ul { padding-left: 20px; }
  .about-content li { margin-bottom: 12px; }

  /* Card Grid */
  .services-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(340px, 1fr)); gap: 32px; }

  .service-card {
    background: var(--card-bg); border-radius: 28px; overflow: hidden;
    border: 1px solid rgba(255,255,255,0.08); transition: 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    box-shadow: 0 10px 25px rgba(0,0,0,0.3);
  }

  .service-card:hover { transform: translateY(-10px); border-color: var(--solar); box-shadow: 0 20px 40px rgba(217, 119, 6, 0.2); }

  .logo-box {
    height: 200px; background: #ffffff; display: flex; 
    align-items: center; justify-content: center; padding: 24px;
  }
  .logo-box img { max-width: 100%; max-height: 100%; object-fit: contain; }

  .card-content { padding: 32px; }
  .card-content h3 { margin-top: 0; color: var(--primary); font-size: 1.6rem; }
  .india-card h3 { color: var(--solar); }

  /* Additional Link Sections */
  .links-section {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 32px;
    margin-top: 60px;
    margin-bottom: 60px;
  }
  
  .link-card {
    background: var(--card-bg);
    padding: 35px;
    border-radius: 28px;
    border: 1px solid rgba(255,255,255,0.08);
    box-shadow: 0 10px 25px rgba(0,0,0,0.3);
  }

  .link-card h3 {
    margin-top: 0;
    color: var(--accent);
    font-size: 1.4rem;
    margin-bottom: 20px;
  }

  .link-card ul {
    list-style-type: none;
    padding: 0;
    margin: 0;
  }

  .link-card li {
    margin-bottom: 12px;
  }

  .link-card a {
    color: #cbd5e1;
    text-decoration: none;
    transition: color 0.3s ease;
  }

  .link-card a:hover {
    color: var(--solar);
  }

  /* Chatbot */
  #chat-toggle {
    position: fixed; bottom: 32px; right: 32px; 
    background: linear-gradient(135deg, #2563eb, #059669); 
    color: #ffffff; border: none; width: 68px; height: 68px; border-radius: 20px; 
    font-size: 30px; cursor: pointer; box-shadow: 0 15px 40px rgba(37, 99, 235, 0.4); z-index: 1000;
    transition: 0.3s;
  }
  #chat-toggle:hover {
    transform: scale(1.08);
  }

  #chatbox {
    position: fixed; bottom: 115px; right: 32px; width: 350px; height: 520px;
    background: #111827; border-radius: 28px; display: none; flex-direction: column; 
    z-index: 999; border: 1px solid rgba(255,255,255,0.08); overflow: hidden;
    box-shadow: 0 25px 50px rgba(0,0,0,0.6);
  }

  #chat-header { background: #030712; color: #ffffff; padding: 20px; font-weight: bold; font-size: 1.1rem; }
  #chat-messages { flex: 1; padding: 18px; overflow-y: auto; display: flex; flex-direction: column; gap: 12px; }
  .msg { padding: 12px 18px; border-radius: 16px; font-size: 0.95rem; max-width: 82%; }
  .ai { background: #1f2937; align-self: flex-start; color: #e5e7eb; }
  .user { background: var(--primary); align-self: flex-end; color: #ffffff; }

  #chat-form { padding: 16px; display: flex; gap: 12px; background: #030712; }
  #chat-input { flex: 1; background: #1f2937; border: 1px solid #374151; color: #ffffff; padding: 10px 14px; border-radius: 12px; outline: none; }
  #chat-input:focus { border-color: var(--primary); }

  .page { display: none; animation: fadeIn 0.5s ease-in-out; }
  .page.active { display: block; }
  @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
</style>
